# ═══════════════════════════════════════════════════════════════════
#  NexaFlow v3.0 — Environment Configuration Example
#  
#  IMPORTANT: Copy this file to .env and fill in your actual values
#  NEVER commit the .env file to version control
# ═══════════════════════════════════════════════════════════════════

# ── Node Environment ────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── Server Ports ────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
DB_PORT=3306

# ── URLs ─────────────────────────────────────────────────────────────
APP_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ═══════════════════════════════════════════════════════════════════
#  DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# MySQL Configuration (Production)
DB_HOST=localhost
DB_NAME=nexaflow_db
DB_USER=nexaflow
DB_PASSWORD=generate_a_strong_random_password_here
DB_ROOT_PASSWORD=generate_another_strong_random_password_here
DB_SSL=false

# Alternative: Use managed database (AWS RDS, Google Cloud SQL, etc.)
# DB_HOST=your-database.xxxxx.us-east-1.rds.amazonaws.com
# DB_POOL_SIZE=20

# ═══════════════════════════════════════════════════════════════════
#  SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# JWT Secret (Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_token_generate_32_characters_here_example_ab12cd34

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://app.yourdomain.com

# Session Configuration
SESSION_SECRET=another_random_secret_key_for_sessions

# ═══════════════════════════════════════════════════════════════════
#  PAYMENT GATEWAY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# ── Razorpay (India Payments) ───────────────────────────────────────
# Sign up: https://razorpay.com
# Get keys from: https://dashboard.razorpay.com/app/keys
# Production keys start with: rzp_live_
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx

# ── Stripe (International Payments) ─────────────────────────────────
# Sign up: https://stripe.com
# Get keys from: https://dashboard.stripe.com/apikeys
# Live keys start with: sk_live_, pk_live_
STRIPE_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════════
#  EMAIL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# ── SMTP Configuration (Gmail recommended for testing) ───────────────
# Gmail: Go to myaccount.google.com → Security → App Passwords
# Set app to "Mail" and device to "Windows Computer"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
SMTP_FROM=NexaFlow <noreply@yourdomain.com>
SMTP_FROM_NAME=NexaFlow

# Alternative: Use SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx

# Alternative: Use AWS SES
# AWS_SES_REGION=us-east-1
# AWS_SES_KEY_ID=xxxxxxxxxxxxx
# AWS_SES_SECRET_KEY=xxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════════
#  API KEYS & EXTERNAL SERVICES
# ═══════════════════════════════════════════════════════════════════

# ── Anthropic Claude API ────────────────────────────────────────────
# Sign up: https://console.anthropic.com
# Get API key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ── Exchange Rate API (Optional - for USD to INR conversion) ─────────
# Free tier available at: https://exchangerate-api.com
EXCHANGE_RATE_API_KEY=your_key_here

# ── Google Analytics (Optional) ──────────────────────────────────────
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# ── Sentry Error Tracking (Optional) ────────────────────────────────
# Sign up: https://sentry.io
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ═══════════════════════════════════════════════════════════════════
#  MISCELLANEOUS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# ── Timezone ────────────────────────────────────────────────────────
TZ=Asia/Kolkata

# ── File Upload Configuration ───────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/uploads

# ── Redis Configuration (Optional - for caching/sessions) ───────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Backup Configuration ■────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ── Feature Flags (Optional) ────────────────────────────────────────
ENABLE_DEMO_MODE=false
ENABLE_API_DOCS=true
ENABLE_ADMIN_PANEL=true

# ═══════════════════════════════════════════════════════════════════
#  NOTES:
# ✓ Generate strong secrets using: openssl rand -hex 32
# ✓ Never share these values - rotate keys regularly
# ✓ Use different keys for development and production
# ✓ Store sensitive values in a secure vault (AWS Secrets Manager, etc.)
# ✓ For Docker deployment, use docker secrets or environment files
# ═══════════════════════════════════════════════════════════════════
